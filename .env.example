# JARVIS Cloud Environment Variables
# Copy this to .env for local development
# Set these in Railway Dashboard for cloud deployment

# ==============================================
# REQUIRED FOR PRODUCTION
# ==============================================

# API Security Key (Generate a strong random key)
# Example: openssl rand -hex 32
JARVIS_API_KEY=your-secure-api-key-here

# ==============================================
# AI PROVIDERS (Configure at least one)
# ==============================================

# Default LLM Provider: ollama, copilot, or openai
JARVIS_LLM_PROVIDER=openai

# OpenAI API Key (for cloud deployment)
OPENAI_API_KEY=sk-your-openai-key-here

# OpenAI Model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ==============================================
# OPTIONAL SETTINGS
# ==============================================

# Debug mode (disable in production)
JARVIS_DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR
JARVIS_LOG_LEVEL=INFO

# Server host and port (Railway provides PORT)
JARVIS_API_HOST=0.0.0.0
# JARVIS_API_PORT is set automatically by Railway

# Ollama host (if using local Ollama)
OLLAMA_HOST=http://localhost:11434

# ==============================================
# SECURITY SETTINGS
# ==============================================

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# IP Whitelist (comma-separated, empty for all)
# IP_WHITELIST=192.168.1.1,10.0.0.1

# ==============================================
# DEVICE REGISTRY
# ==============================================

# Device registry persistence (future: Redis URL)
# REDIS_URL=redis://localhost:6379
