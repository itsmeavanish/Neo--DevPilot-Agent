# JARVIS Environment Variables
# Copy to .env and update values

# API Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JARVIS_API_KEY=your-secret-key

# AI Provider: ollama, copilot, or openai
JARVIS_LLM_PROVIDER=ollama

# OpenAI (if using)
OPENAI_API_KEY=sk-your-key

# Ollama (if using)
OLLAMA_HOST=http://localhost:11434

# Server Config
JARVIS_DEBUG=false
JARVIS_API_HOST=0.0.0.0
JARVIS_API_PORT=8000
