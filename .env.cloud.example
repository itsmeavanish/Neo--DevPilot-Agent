# =====================================================
# JARVIS Cloud Environment Configuration
# =====================================================
# Copy this to .env and fill in your values

# API Configuration
JARVIS_API_HOST=0.0.0.0
JARVIS_API_PORT=8000
JARVIS_DEBUG=false
JARVIS_API_KEY=your-secure-api-key-here

# LLM Provider (copilot requires gh CLI on server, use openai/anthropic for cloud)
JARVIS_LLM_PROVIDER=ollama
JARVIS_OLLAMA_HOST=http://localhost:11434
JARVIS_OLLAMA_MODEL=llama3.2

# For cloud AI (recommended for 24/7 availability)
# JARVIS_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key

# Database (use cloud PostgreSQL - Neon, Supabase, Railway)
# JARVIS_DATABASE_URL=postgresql://user:pass@host:5432/jarvis

# Redis (use cloud Redis - Upstash, Railway, Redis Cloud)
# JARVIS_REDIS_URL=redis://user:pass@host:6379

# Remote Laptop Agent (for controlling your laptop when it's on)
JARVIS_REMOTE_AGENT_ENABLED=true
JARVIS_REMOTE_AGENT_URL=
JARVIS_REMOTE_AGENT_TOKEN=

# Kafka (optional - disable for simple deployments)
JARVIS_KAFKA_ENABLED=false
