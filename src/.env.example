# JARVIS - Autonomous Developer OS
# Environment Configuration

# API Settings
JARVIS_API_KEY=your-secret-api-key-here
JARVIS_API_HOST=0.0.0.0
JARVIS_API_PORT=8000
JARVIS_DEBUG=false

# LLM Settings (Ollama)
JARVIS_OLLAMA_HOST=http://localhost:11434
JARVIS_OLLAMA_MODEL=llama3.2
JARVIS_EMBEDDING_MODEL=nomic-embed-text

# ═══════════════════════════════════════════════════
# Phase 2: Memory + RAG Settings
# ═══════════════════════════════════════════════════

# PostgreSQL (with pgvector)
JARVIS_DATABASE_URL=postgresql://jarvis:jarvis_secret@localhost:5432/jarvis

# Redis (for short-term memory)
JARVIS_REDIS_URL=redis://localhost:6379/0

# Execution Settings
JARVIS_COMMAND_TIMEOUT=60
JARVIS_MAX_PLAN_STEPS=20

# Security
JARVIS_SANDBOX_ENABLED=true
JARVIS_APPROVAL_REQUIRED=true

# Logging
JARVIS_LOG_LEVEL=INFO
